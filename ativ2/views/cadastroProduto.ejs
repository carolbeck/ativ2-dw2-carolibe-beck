<%- include('partials/header') %>
<%- include('partials/navbar') %>

<div class="container mt-5">
  <h2>Cadastrar Produto</h2>
  <form action="/produtos/cadastrar" method="POST">
    <div class="mb-3">
      <label for="nome" class="form-label">Nome</label>
      <input type="text" class="form-control" id="nome" name="nome" required>
    </div>
    <div class="mb-3">
      <label for="linha" class="form-label">Linha</label>
      <input type="text" class="form-control" id="linha" name="linha">
    </div>
    <div class="mb-3">
      <label for="indicacao" class="form-label">Indicação</label>
      <input type="text" class="form-control" id="indicacao" name="indicacao">
    </div>
    <div class="mb-3">
      <label for="descricao" class="form-label">Descrição</label>
      <textarea class="form-control" id="descricao" name="descricao" rows="3"></textarea>
    </div>
    <div class="mb-3">
      <label for="preco" class="form-label">Preço</label>
      <input type="number" step="0.01" class="form-control" id="preco" name="preco" required>
    </div>
    <div class="mb-3">
      <label for="imagem" class="form-label">URL da imagem</label>
      <input type="text" class="form-control" id="imagem" name="imagem" placeholder="/imgs/nome-da-imagem.jpg ou https://...">
      <div class="form-text">Use um caminho de imagem válido, por exemplo <code>/imgs/produto1.jpg</code> ou um URL completo.</div>
    </div>
    <div class="mb-3">
      <label for="icone" class="form-label">Ícone Bootstrap (opcional)</label>
      <input type="text" class="form-control" id="icone" name="icone" placeholder="bi-star-fill">
      <div class="form-text">Exemplo: bi-star-fill, bi-droplet-half, bi-bandage.</div>
    </div>
    <button type="submit" class="btn btn-primary">Cadastrar</button>
    <a href="/produtos" class="btn btn-secondary ms-2">Voltar</a>
  </form>
</div>

<%- include('partials/footer') %>
