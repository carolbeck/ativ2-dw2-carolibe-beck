<%- include('partials/header') %>
<%- include('partials/navbar') %>

<section class="py-5 bg-white">
  <div class="container">
    <div class="text-center mb-5">
      <span class="eyebrow">Pedidos</span>
      <h1 class="display-6 fw-bold">Acompanhe os pedidos do salão</h1>
      <p class="text-muted mx-auto mb-0" style="max-width: 680px;">Veja o andamento das entregas, o cliente responsável e os produtos escolhidos.</p>
    </div>

    <div class="mb-4">
      <a href="/pedidos/cadastro" class="btn btn-danger">+ Novo Pedido</a>
    </div>

    <% if (pedidos && pedidos.length > 0) { %>
      <div class="row g-4">
        <% pedidos.forEach((pedido) => { %>
          <div class="col-12 col-md-6 col-lg-4">
            <div class="card order-card h-100 shadow-sm">
              <div class="card-body">
                <div class="d-flex align-items-start justify-content-between mb-3">
                  <div>
                    <h5 class="card-title mb-1">Pedido #<%= pedido.id %></h5>
                    <p class="mb-0 text-muted">Cliente: <strong><%= pedido.Cliente ? pedido.Cliente.nome : 'N/A' %></strong></p>
                  </div>
                </div>

                <div class="order-icon mb-3 text-danger">
                  <i class="bi bi-bag-fill fs-1"></i>
                </div>

                <p class="card-text mb-3">
                  <strong>Produtos:</strong> 
                  <% if (pedido.Produtos && pedido.Produtos.length > 0) { %>
                    <ul class="list-unstyled small mt-2">
                      <% pedido.Produtos.forEach((produto) => { %>
                        <li>• <%= produto.nome %> - R$ <%= produto.preco.toFixed(2) %></li>
                      <% }) %>
                    </ul>
                  <% } else { %>
                    <span class="text-muted">Nenhum produto</span>
                  <% } %>
                </p>

                <div class="order-meta list-group list-group-flush">
                  <div class="list-group-item px-0 py-2 d-flex justify-content-between align-items-center">
                    <span class="text-muted">Total</span>
                    <span class="fw-semibold">R$ <%= pedido.total.toFixed(2) %></span>
                  </div>
                  <div class="list-group-item px-0 py-2 d-flex justify-content-between align-items-center">
                    <span class="text-muted">Data</span>
                    <span class="fw-semibold"><%= new Date(pedido.createdAt).toLocaleDateString('pt-BR') %></span>
                  </div>
                </div>
              </div>
              <div class="card-footer bg-transparent border-0 pt-0">
                <a href="/pedidos" class="text-decoration-none text-danger fw-semibold">Ver mais</a>
              </div>
            </div>
          </div>
        <% }) %>
      </div>
    <% } else { %>
      <div class="alert alert-info text-center">
        <p>Nenhum pedido cadastrado ainda.</p>
        <a href="/pedidos/cadastro" class="btn btn-danger btn-sm">Criar primeiro pedido</a>
      </div>
    <% } %>
  </div>
</section>

<%- include('partials/footer') %>

