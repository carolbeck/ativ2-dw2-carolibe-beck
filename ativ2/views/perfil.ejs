<%- include('partials/header') %>
<%- include('partials/navbar') %>

<div class="container mt-5">
  <div class="row g-4">
    <div class="col-lg-5">
      <div class="card profile-card shadow-sm h-100">
        <div class="card-body">
          <span class="eyebrow">Perfil</span>
          <h3 class="card-title mb-3">Informações do usuário</h3>
          <p class="text-muted mb-4">Gerencie clientes com um registro mais elegante e adequado ao ambiente profissional do salão.</p>
          <p class="mb-2"><strong>Nome:</strong> <%= user.nome %></p>
          <p class="mb-2"><strong>Cargo:</strong> <%= user.cargo %></p>
          <p class="mb-2"><strong>Unidade:</strong> <%= user.unidade %></p>
          <p class="text-muted">Use o formulário ao lado para registrar clientes e acompanhar os registros em <strong>Clientes</strong>.</p>
        </div>
      </div>
    </div>

    <div class="col-lg-7">
      <div class="card form-card shadow-sm h-100">
        <div class="card-body">
          <h3 class="card-title mb-3">Cadastro de cliente</h3>
          <p class="text-muted mb-4">Preencha os dados abaixo para inserir um novo cliente no histórico do salão.</p>
          <% if (message) { %>
            <div class="alert alert-info"><%= message %></div>
          <% } %>
          <form action="/perfil" method="POST">
            <div class="mb-3">
              <label for="nome" class="form-label">Nome completo</label>
              <input type="text" id="nome" name="nome" class="form-control" placeholder="Digite o nome" required>
            </div>
            <div class="mb-3">
              <label for="cpf" class="form-label">CPF</label>
              <input type="text" id="cpf" name="cpf" class="form-control" placeholder="000.000.000-00" required>
            </div>
            <div class="mb-3">
              <label for="endereco" class="form-label">Endereço</label>
              <input type="text" id="endereco" name="endereco" class="form-control" placeholder="Rua, número, bairro" required>
            </div>
            <div class="mb-3">
              <label for="email" class="form-label">Email</label>
              <input type="email" id="email" name="email" class="form-control" placeholder="email@exemplo.com">
            </div>
            <button type="submit" class="btn btn-danger">Registrar cliente</button>
          </form>
        </div>
      </div>
    </div>
  </div>

  <div class="mt-4">
    <a href="/clientes" class="btn btn-outline-danger me-2">Ver clientes cadastrados</a>
    <a href="/" class="btn btn-secondary">Voltar para home</a>
  </div>
</div>

<%- include('partials/footer') %>
